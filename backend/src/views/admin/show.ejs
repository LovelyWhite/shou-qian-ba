<%- include('../partials/head', { title: '申请详情' }) %>
<%- include('../partials/nav') %>

<main class="container">

  <div class="page-header">
    <div class="page-header__main">
    </div>
  </div>

  <div class="card">
    <h2 class="h2">详情</h2>
    <div class="detail-grid">
      <div class="detail-item">
        <div class="detail-item__k">订单号</div>
        <div class="detail-item__v"><%= item.orderNo || '-' %></div>
      </div>
      <div class="detail-item">
        <div class="detail-item__k">状态</div>
        <div class="detail-item__v">
          <span class="status-text <%= item.status === 'completed' ? 'status-text--completed' : 'status-text--pending' %>"><%= item.status === 'completed' ? '已完成' : '未完成' %></span>
        </div>
      </div>
      <div class="detail-item">
        <div class="detail-item__k">商户名称</div>
        <div class="detail-item__v"><%= item.merchantName || '-' %></div>
      </div>
      <div class="detail-item">
        <div class="detail-item__k">联系方式</div>
        <div class="detail-item__v"><%= item.contact || '-' %></div>
      </div>
      <div class="detail-item">
        <div class="detail-item__k">区域编码</div>
        <div class="detail-item__v"><%= item.areaCode || '-' %></div>
      </div>
      <div class="detail-item">
        <div class="detail-item__k">省市区</div>
        <div class="detail-item__v"><%= item.areaText || '-' %></div>
      </div>
      <div class="detail-item detail-item--full">
        <div class="detail-item__k">详细地址</div>
        <div class="detail-item__v"><pre class="pre"><%= item.addressDetail || '-' %></pre></div>
      </div>
      <div class="detail-item">
        <div class="detail-item__k">开户银行名称</div>
        <div class="detail-item__v"><%= item.bankName || '-' %></div>
      </div>
      <div class="detail-item detail-item--full">
        <div class="detail-item__k">备注</div>
        <div class="detail-item__v"><pre class="pre"><%= item.remark || '-' %></pre></div>
      </div>

      <div class="detail-item detail-item--full">
        <div class="detail-item__k">创建 / 更新 / 完成时间</div>
        <div class="detail-item__v">
          创建：<%= formatDate(item.createdAt) %>
          <span class="muted">｜</span>
          更新：<%= formatDate(item.updatedAt) %>
          <span class="muted">｜</span>
          完成：<%= formatDate(item.completedAt) %>
        </div>
      </div>
      <div class="detail-item detail-item--full">
        <div class="detail-item__k">二维码</div>
        <div class="detail-item__v detail-item__v--center">
          <a class="js-image-link" href="/admin/applications/<%= item._id %>/code.png" rel="noreferrer" data-is-image="1">
            <img class="qrcode__img" src="/admin/applications/<%= item._id %>/code.png" alt="" />
          </a>
        </div>
      </div>
    </div>
    <h2 class="h2" style='margin-top: 20px;'>上传材料</h2>
    <%
      const groups = [
        ['身份证人像面', item.files && item.files.idCardFront],
        ['身份证国徽面', item.files && item.files.idCardBack],
        ['银行卡正面', item.files && item.files.bankCard],
        ['店铺门头照', item.files && item.files.shopFront],
        ['店铺内景照', item.files && item.files.shopInside],
        ['营业执照', item.files && item.files.license],
      ]

      function isImageUrl(url) {
        return /\.(png|jpe?g|gif|webp|bmp|svg)$/i.test(url || '')
      }
    %>

    <% groups.forEach(function(group) { %>
      <div class="file-group">
        <div class="file-group__title"><%= group[0] %></div>
        <div class="file-grid">
          <% const list = Array.isArray(group[1]) ? group[1] : [] %>
          <% if (list.length === 0) { %>
            <div class="muted">未上传</div>
          <% } else { %>
            <% list.forEach(function(f) { %>
              <% const isImg = isImageUrl(f.url) %>
              <div class="file-item">
                <a class="js-image-link" href="<%= f.url %>" <%= isImg ? '' : 'target="_blank"' %> rel="noreferrer" data-is-image="<%= isImg ? '1' : '0' %>">
                  <% if (isImg) { %>
                    <img class="thumb" src="<%= f.url %>" alt="" />
                  <% } else { %>
                    <div class="thumb thumb--file">文件</div>
                  <% } %>
                </a>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</main>

<div class="img-preview" id="imgPreview" aria-hidden="true">
  <div class="img-preview__backdrop"></div>
  <div class="img-preview__panel" role="dialog" aria-modal="true">
    <img class="img-preview__img" id="imgPreviewImg" alt="" />
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('imgPreview')
    var img = document.getElementById('imgPreviewImg')
    if (!root || !img) return

    function open(url) {
      img.src = url
      root.classList.add('is-open')
      root.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    }

    function close() {
      root.classList.remove('is-open')
      root.setAttribute('aria-hidden', 'true')
      img.removeAttribute('src')
      document.body.style.overflow = ''
    }

    document.addEventListener('click', function (e) {
      var target = e.target
      var link = target && target.closest ? target.closest('a.js-image-link') : null
      if (link && link.getAttribute('data-is-image') === '1') {
        e.preventDefault()
        open(link.getAttribute('href'))
        return
      }

      if (root.classList.contains('is-open') && root.contains(target)) {
        e.preventDefault()
        close()
      }
    })

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && root.classList.contains('is-open')) close()
    })
  })()
</script>

<%- include('../partials/foot') %>
