<%- include('../partials/head', { title: '申请列表' }) %>
<%- include('../partials/nav') %>

<main class="container container--fluid">
  <div class="row">
    <form method="get" action="/admin/applications" style="display:flex;gap:8px;align-items:center">
      <input class="input" name="q" value="<%= q || '' %>" placeholder="输入订单号 / 商家名称 / 联系方式" style="min-width:240px" />
      <button class="btn btn--secondary" type="submit" style="min-width:65px;">搜索</button>
      <a class="btn btn--ghost" href="/admin/applications" style="min-width:65px;">重置</a>
    </form>
    <div class="row__actions">
      <a class="btn" href="/admin/applications/new">新建</a>
      <a class="btn btn--secondary" href="/admin/applications/export.xlsx">导出 Excel</a>
    </div>
  </div>

  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>订单号</th>
          <th>更新时间</th>
          <th>商户名称</th>
          <th>备注</th>
          <th>小程序码</th>
          <th>状态</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (!items || items.length === 0) { %>
          <tr>
            <td colspan="7" class="muted">暂无数据</td>
          </tr>
        <% } else { %>
          <% items.forEach(function(item) { %>
            <tr>
              <td><%= item.orderNo || '' %></td>
              <td><%= formatDate(item.updatedAt) %></td>
              <td><%= item.merchantName %></td>
              <td>
                <form class="js-remark-form" method="post" action="/admin/applications/<%= item._id %>/remark" style="display:flex;gap:8px;align-items:center">
                  <input class="input" name="remark" value="<%= item.remark || '' %>" placeholder="备注" style="min-width:240px" />
                  <input type="hidden" name="page" value="<%= pagination && pagination.page ? pagination.page : 1 %>" />
                  <input type="hidden" name="q" value="<%= q || '' %>" />
                  <button class="btn btn--secondary" type="submit" style="min-width:65px;">保存</button>
                </form>
              </td>
              <td>
                <a class="js-image-link" href="/applications/<%= item._id %>/code.png" rel="noreferrer" data-is-image="1">
                  <img src="/admin/applications/<%= item._id %>/code.png" alt="" style="width:56px;height:56px;object-fit:contain;background:#fff;border-radius:6px" />
                </a>
              </td>
              <td>
                <span class="<%= item.status === 'completed' ? 'status-text status-text--completed' : 'status-text status-text--pending' %>"><%= statusText(item.status) %></span>
              </td>
              <td class="right">
                <a class="btn btn--secondary" href="/admin/applications/<%= item._id %>">查看</a>
                <form method="post" action="/admin/applications/<%= item._id %>/delete" style="display:inline;margin-left:8px" onsubmit="return confirm('确认删除？')">
                  <button class="btn btn--danger" type="submit">删除</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (pagination && pagination.totalPages > 1) { %>
    <div class="row" style="margin-top:12px">
      <div class="row__actions" style="gap:8px;align-items:center">
        <span class="muted">共 <%= pagination.total %> 条，第 <%= pagination.page %> / <%= pagination.totalPages %> 页</span>

        <% if (pagination.page > 1) { %>
          <a class="btn btn--secondary" href="/admin/applications?page=<%= pagination.page - 1 %><%= q ? '&q=' + encodeURIComponent(q) : '' %>">上一页</a>
        <% } else { %>
          <span class="btn btn--secondary" style="opacity:.5;pointer-events:none">上一页</span>
        <% } %>

        <% if (pagination.page < pagination.totalPages) { %>
          <a class="btn btn--secondary" href="/admin/applications?page=<%= pagination.page + 1 %><%= q ? '&q=' + encodeURIComponent(q) : '' %>">下一页</a>
        <% } else { %>
          <span class="btn btn--secondary" style="opacity:.5;pointer-events:none">下一页</span>
        <% } %>
      </div>
    </div>
  <% } %>
</main>

<div class="toast" id="toast" role="status" aria-live="polite" aria-atomic="true"></div>

<div class="img-preview" id="imgPreview" aria-hidden="true">
  <div class="img-preview__backdrop"></div>
  <div class="img-preview__panel" role="dialog" aria-modal="true">
    <img class="img-preview__img" id="imgPreviewImg" alt="" />
  </div>
</div>

<style>
  .toast { position: fixed; left: 50%; top: 16px; transform: translateX(-50%); background: rgba(0,0,0,.82); color: #fff; padding: 10px 14px; border-radius: 10px; font-size: 14px; font-weight: 600; z-index: 1100; opacity: 0; pointer-events: none; transition: opacity .16s ease; max-width: min(520px, calc(100vw - 24px)); text-align: center; }
  .toast.is-open { opacity: 1; }
  .img-preview { position: fixed; inset: 0; display: none; z-index: 1000; }
  .img-preview.is-open { display: block; }
  .img-preview__backdrop { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.65); }
  .img-preview__panel { position: relative; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; padding: 20px; box-sizing: border-box; }
  .img-preview__img { max-width: 100%; max-height: 100%; object-fit: contain; background: #fff; border-radius: 8px; }
</style>

<script>
  (function () {
    var toastTimer = null
    var toastEl = document.getElementById('toast')

    function showToast(message) {
      if (!toastEl) return
      toastEl.textContent = message
      toastEl.classList.add('is-open')
      if (toastTimer) window.clearTimeout(toastTimer)
      toastTimer = window.setTimeout(function () {
        toastEl.classList.remove('is-open')
      }, 1600)
    }

    try {
      var url = new URL(window.location.href)
      if (url.searchParams.get('saved') === '1') {
        showToast('保存成功')
        url.searchParams.delete('saved')
        var next = url.pathname + (url.searchParams.toString() ? '?' + url.searchParams.toString() : '') + url.hash
        window.history.replaceState(null, '', next)
      }
    } catch (e) {}

    document.addEventListener('submit', function (e) {
      var form = e.target
      if (!form || !form.classList || !form.classList.contains('js-remark-form')) return
      e.preventDefault()
      var action = form.getAttribute('action') || ''
      if (!action) return

      var fd = new FormData(form)
      var params = new URLSearchParams()
      fd.forEach(function (value, key) {
        if (typeof value === 'string') params.append(key, value)
      })

      fetch(action, {
        method: 'POST',
        headers: {
          Accept: 'application/json',
          'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
        },
        body: params.toString(),
        credentials: 'same-origin',
      })
        .then(function (res) {
          if (!res || !res.ok) throw new Error('request failed')
          return res.json().catch(function () {
            return {}
          })
        })
        .then(function () {
          showToast('保存成功')
        })
        .catch(function () {
          showToast('保存失败')
        })
    })

    var root = document.getElementById('imgPreview')
    var img = document.getElementById('imgPreviewImg')
    if (!root || !img) return

    function open(url) {
      img.src = url
      root.classList.add('is-open')
      root.setAttribute('aria-hidden', 'false')
      document.body.style.overflow = 'hidden'
    }

    function close() {
      root.classList.remove('is-open')
      root.setAttribute('aria-hidden', 'true')
      img.removeAttribute('src')
      document.body.style.overflow = ''
    }

    document.addEventListener('click', function (e) {
      var target = e.target
      var link = target && target.closest ? target.closest('a.js-image-link') : null
      if (link && link.getAttribute('data-is-image') === '1') {
        e.preventDefault()
        open(link.getAttribute('href'))
        return
      }

      if (root.classList.contains('is-open') && root.contains(target)) {
        e.preventDefault()
        close()
      }
    })

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && root.classList.contains('is-open')) close()
    })
  })()
</script>

<%- include('../partials/foot') %>
