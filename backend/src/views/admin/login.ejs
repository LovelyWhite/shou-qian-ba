<%- include('../partials/head', { title: title || '登录' }) %>

<main class="container">
  <div class="card" style="max-width:420px;margin:36px auto 0">
    <h1 class="h1" style="margin-bottom:10px">后台登录</h1>
    <p class="muted" style="margin:0 0 14px">请输入账号密码</p>

    <% if (err) { %>
      <div class="card" style="border-color:rgba(238,10,36,.3);background:rgba(238,10,36,.06)">
        <div style="font-weight:700;color:#ee0a24">账号或密码错误</div>
      </div>
    <% } %>

    <form method="post" action="/admin/login">
      <input type="hidden" name="next" value="<%= next || '' %>" />

      <div class="form-row" style="grid-template-columns: 80px 1fr">
        <div class="label">账号</div>
        <div>
          <input class="input" name="username" autocomplete="username" value="admin" />
        </div>
      </div>

      <div class="form-row" style="grid-template-columns: 80px 1fr">
        <div class="label">密码</div>
        <div>
          <input class="input" type="password" name="password" autocomplete="current-password" />
        </div>
      </div>

      <div class="form-actions">
        <button class="btn" type="submit">登录</button>
      </div>
    </form>
  </div>
</main>

<%- include('../partials/foot') %>
