<view class="tabbar">
  <view class="tabbar__content">
    <view
      wx:for="{{ list }}"
      wx:key="pagePath"
      class="tabbar__item {{ selected === index ? 'tabbar__item--active' : '' }}"
      data-index="{{ index }}"
      data-path="{{ item.pagePath }}"
      bindtap="onTap"
    >
      <van-icon
        name="{{ item.icon }}"
        size="22px"
        color="{{ selected === index ? selectedColor : color }}"
      />
      <view class="tabbar__text">{{ item.text }}</view>
    </view>
  </view>
  <view class="tabbar__safe"></view>
</view>
