.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.tabbar__safe {
  height: env(safe-area-inset-bottom);
  background: #ffffff;
}

.tabbar__content {
  height: 112rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
}

.tabbar__item {
  flex: 1;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7d7e80;
}

.tabbar__item--active {
  color: #1989fa;
}

.tabbar__text {
  font-size: 24rpx;
  line-height: 24rpx;
  margin-top: 8rpx;
}
