page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background:#F2F2F2
}

.scrollarea {
  flex: 1;
}
.page {
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.banner-swiper {
  width: 100%;
  height: 832rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

.apply-section {
  background: #ffffff;
  padding: 40rpx 0;
  margin-top:20rpx;
}

.apply-btn {
  width: 640rpx;
  height: 96rpx;
  margin: 0 auto;
  padding: 0;
  border-radius: 999rpx;
  background: #ff9800;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 96rpx;
}

.detail-wrap {
  padding-right: 10rpx;
  box-sizing: border-box;
  margin-top: 10rpx;
}

.detail-image {
  width: 100%;
  display: block;
  padding: 0;
  border-radius: 0;
}
