.scrollarea {
  height: 100vh;
}
.section {
  padding: 12px;
}
.submit-wrap {
  padding: 12px 0;
}
.submit-btn {
  width: 100%;
  height: 44px;
  line-height: 44px;
  background-color: #1989fa;
  color: #fff;
  border: none;
  border-radius: 4px;
}
.submit-btn--secondary {
  background-color: #ffffff;
  color: #1989fa;
  border: 1px solid #1989fa;
}
.result-actions {
  margin: 8px 0 12px;
}
.result-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 8px;
}
.code-image {
  width: 100%;
}
